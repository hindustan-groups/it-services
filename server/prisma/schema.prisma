// Prisma schema — Hindustan Projects
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// Service — IT services offered by the company
// ─────────────────────────────────────────────────────────────────
model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  fullDescription  String
  icon             String
  order            Int      @default(0)
  isActive         Boolean  @default(true)
  // Rich detail fields for ServiceDetailPage
  tag              String?              // e.g. "Most Popular"
  deliveryTime     String?              // e.g. "2–4 Weeks"
  techStack        String[]             // e.g. ["React", "Node.js"]
  keyFeatures      String[]             // bullet points
  process          Json?                // [{step, title, desc}]
  colorFrom        String?              // Tailwind gradient from color
  colorTo          String?              // Tailwind gradient to color
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([isActive, order])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────
// Project — Portfolio items
// ─────────────────────────────────────────────────────────────────
model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  clientName   String
  description  String
  thumbnailUrl String?
  images       String[] // Array of image URLs (Cloudinary)
  technologies String[] // e.g. ["React", "Node.js", "PostgreSQL"]
  category     String   // e.g. "Web", "Marketing", "Branding"
  isFeatured   Boolean  @default(false)
  liveUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  socialDrafts SocialPostDraft[]

  @@index([slug])
  @@index([isFeatured])
  @@index([category])
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────────
// TeamMember — About page team section
// ─────────────────────────────────────────────────────────────────
model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  photoUrl    String?
  bio         String?
  linkedinUrl String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("team_members")
}

// ─────────────────────────────────────────────────────────────────
// Testimonial — Client reviews
// ─────────────────────────────────────────────────────────────────
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  text      String
  rating    Int      @default(5)
  avatarUrl String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────────
// FAQ — Frequently asked questions
// ─────────────────────────────────────────────────────────────────
model Faq {
  id       String  @id @default(cuid())
  question String
  answer   String
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("faqs")
}

// ─────────────────────────────────────────────────────────────────
// SiteSetting — Key-value store for contact info, social links etc
// ─────────────────────────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────────
// Milestone — Company timeline on About page
// ─────────────────────────────────────────────────────────────────
model Milestone {
  id        String   @id @default(cuid())
  year      String
  title     String
  desc      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("milestones")
}

// ─────────────────────────────────────────────────────────────────
// Partner — Client logo banner
// ─────────────────────────────────────────────────────────────────
model Partner {
  id       String  @id @default(cuid())
  name     String
  logoUrl  String?
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("partners")
}

// ─────────────────────────────────────────────────────────────────
enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model ContactLead {
  id                String       @id @default(cuid())
  name              String
  email             String
  phone             String?
  message           String
  serviceInterested String?
  status            LeadStatus   @default(NEW)
  notes             String?      @default("")
  estimatedBudget   String?      @default("")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  attachments       Attachment[]
  deletedAt         DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("contact_leads")
}

// ─────────────────────────────────────────────────────────────────
// Admin — CMS dashboard users
// ─────────────────────────────────────────────────────────────────
enum AdminRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model Admin {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  role             AdminRole @default(ADMIN)
  isActive         Boolean   @default(true)
  loginAttempts    Int       @default(0)
  lockoutUntil     DateTime?
  refreshToken     String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  passwordHistories PasswordHistory[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([email])
  @@map("admins")
}

// ─────────────────────────────────────────────────────────────────
// Careers — Job Postings & Applications
// ─────────────────────────────────────────────────────────────────
enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  NEW
  SHORTLISTED
  REJECTED
  HIRED
}

model JobPosting {
  id                 String           @id @default(cuid())
  title              String
  slug               String           @unique
  department         String
  location           String
  jobType            JobType          @default(FULL_TIME)
  experienceRequired String
  description        String
  responsibilities   String[]
  requirements       String[]
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  applications       JobApplication[]

  @@index([slug])
  @@index([isActive])
  @@map("job_postings")
}

model JobApplication {
  id           String            @id @default(cuid())
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String
  resumeUrl    String
  coverLetter  String?
  status       ApplicationStatus @default(NEW)
  createdAt    DateTime          @default(now())
  deletedAt    DateTime?

  @@index([jobPostingId])
  @@index([deletedAt])
  @@map("job_applications")
}

// ─────────────────────────────────────────────────────────────────
// LegalPage — Dynamic terms and policy pages
// ─────────────────────────────────────────────────────────────────
enum LegalPageType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  REFUND_POLICY
}

model LegalPage {
  id          String        @id @default(cuid())
  pageType    LegalPageType @unique
  title       String
  content     String        // Stored as long HTML/Markdown text
  lastUpdated DateTime      @default(now()) @updatedAt
  updatedBy   String?       // admin id reference

  @@index([pageType])
  @@map("legal_pages")
}

// ─────────────────────────────────────────────────────────────────
// Work Management System Models
// ─────────────────────────────────────────────────────────────────

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model ClientProject {
  id                String             @id @default(cuid())
  clientName        String
  projectTitle      String
  description       String?
  status            ProjectStatus      @default(PLANNING)
  priority          ProjectPriority    @default(MEDIUM)
  progress          Int                @default(0)
  startDate         DateTime
  deadline          DateTime
  assignedTo        String?
  budget            String?
  tags              String[]
  notes             String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  tasks             WorkTask[]
  tickets           SupportTicket[]
  billingMilestones BillingMilestone[]
  clientId          String?
  client            Client?            @relation(fields: [clientId], references: [id], onDelete: SetNull)
  attachments       Attachment[]
  hasFeedback       Boolean            @default(false)
  deletedAt         DateTime?

  @@index([clientId])
  @@index([deletedAt])
  @@map("client_projects")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  BLOCKED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model WorkTask {
  id              String         @id @default(cuid())
  title           String
  description     String?
  status          TaskStatus     @default(TODO)
  priority        TaskPriority   @default(MEDIUM)
  dueDate         DateTime?
  assignedTo      String?
  clientProjectId String?
  clientProject   ClientProject? @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
  tags            String[]
  creatorId       String?
  assignedToAdminId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attachments     Attachment[]

  @@index([clientProjectId])
  @@map("work_tasks")
}

model QuickNote {
  id        String   @id @default(cuid())
  title     String?
  content   String
  color     String   @default("yellow") // yellow | blue | green | pink | purple
  isPinned  Boolean  @default(false)
  creatorId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quick_notes")
}

model ActivityLog {
  id         String   @id @default(cuid())
  adminId    String
  adminEmail String
  action     String   // e.g. "CREATE", "UPDATE", "DELETE"
  entity     String   // e.g. "ClientProject", "WorkTask", "QuickNote"
  details    String   // Description of the action (e.g. "Created project 'E-Commerce Website'")
  createdAt  DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─────────────────────────────────────────────────────────────────
// Blog System
// ─────────────────────────────────────────────────────────────────

enum BlogPostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model BlogPost {
  id               String         @id @default(cuid())
  title            String
  slug             String         @unique
  excerpt          String         // Short summary for listing/SEO
  content          String         // Full HTML content
  featuredImageUrl String?
  category         String         // e.g. "Web Development", "Digital Marketing"
  tags             String[]
  authorName       String         @default("Hindustan Projects")
  authorId         String?        // Reference to Admin id
  status           BlogPostStatus @default(DRAFT)
  metaTitle        String?
  metaDescription  String?
  viewCount        Int            @default(0)
  isFeatured       Boolean        @default(false)
  publishedAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  comments         BlogComment[]
  deletedAt        DateTime?

  @@index([slug])
  @@index([status, publishedAt])
  @@index([category])
  @@index([isFeatured])
  @@index([deletedAt])
  @@map("blog_posts")
}

model BlogComment {
  id          String   @id @default(cuid())
  blogPostId  String
  blogPost    BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  name        String
  email       String
  comment     String
  isApproved  Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([blogPostId])
  @@index([isApproved])
  @@map("blog_comments")
}

// ─────────────────────────────────────────────────────────────────
// SocialPostDraft — Pre-formatted social drafts for featured projects
// ─────────────────────────────────────────────────────────────────
enum SocialPostStatus {
  DRAFT
  POSTED
}

model SocialPostDraft {
  id        String           @id @default(cuid())
  projectId String
  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  text      String
  status    SocialPostStatus @default(DRAFT)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([projectId])
  @@map("social_post_drafts")
}

// ─────────────────────────────────────────────────────────────────
// ChatbotInquiry — User questions captured via public FAQ Chatbot
// ─────────────────────────────────────────────────────────────────
model ChatbotInquiry {
  id         String   @id @default(cuid())
  question   String
  answer     String?
  isAnswered Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isAnswered])
  @@index([createdAt])
  @@map("chatbot_inquiries")
}

// ─────────────────────────────────────────────────────────────────
// ErrorLog — Lightweight custom backup error tracker
// ─────────────────────────────────────────────────────────────────
model ErrorLog {
  id           String   @id @default(cuid())
  source       String   // "FRONTEND" | "BACKEND"
  errorMessage String
  pageOrRoute  String
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([source])
  @@index([createdAt])
  @@map("error_logs")
}

// ─────────────────────────────────────────────────────────────────
// PageVisit — Lightweight custom visitor tracker
// ─────────────────────────────────────────────────────────────────
model PageVisit {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ipHash    String
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
  @@map("page_visits")
}

model PasswordHistory {
  id           String   @id @default(cuid())
  adminId      String
  admin        Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  passwordHash String
  createdAt    DateTime @default(now())

  @@index([adminId])
  @@map("password_histories")
}

model Client {
  id                 String          @id @default(cuid())
  name               String
  email              String          @unique
  passwordHash       String?
  isActive           Boolean         @default(true)
  inviteToken        String?         @unique
  inviteTokenExpires DateTime?
  projects           ClientProject[]
  tickets            SupportTicket[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@map("clients")
}

model Attachment {
  id              String         @id @default(cuid())
  fileName        String
  fileUrl         String
  fileType        String
  fileSize        Int?
  publicId        String?
  createdAt       DateTime       @default(now())

  // Scoped Relations
  leadId          String?
  lead            ContactLead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  
  taskId          String?
  task            WorkTask?      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  clientProjectId String?
  clientProject   ClientProject? @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([taskId])
  @@index([clientProjectId])
  @@map("attachments")
}

model SupportTicket {
  id              String          @id @default(cuid())
  subject         String
  category        String          // e.g. "TECHNICAL" | "BILLING" | "UPDATE" | "OTHER"
  status          String          @default("OPEN") // "OPEN" | "IN_PROGRESS" | "RESOLVED"
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientProjectId String?
  clientProject   ClientProject?  @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
  clientHasUnread Boolean         @default(false)
  adminHasUnread  Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  messages        TicketMessage[]

  @@index([clientId])
  @@index([clientProjectId])
  @@map("support_tickets")
}

model TicketMessage {
  id         String        @id @default(cuid())
  ticketId   String
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderType String        // "CLIENT" | "ADMIN"
  senderName String
  senderId   String        // client id or admin id
  message    String
  fileUrl    String?
  fileName   String?
  createdAt  DateTime      @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model BillingMilestone {
  id              String        @id @default(cuid())
  title           String
  amount          Float
  dueDate         DateTime?
  status          String        @default("PENDING") // "PENDING" | "PAID" | "OVERDUE"
  clientProjectId String
  clientProject   ClientProject @relation(fields: [clientProjectId], references: [id], onDelete: Cascade)
  deliverables    Json?         // e.g. [{ name: "Figma Link", url: "https://figma.com/..." }]
  paidAt          DateTime?
  invoiceUrl      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([clientProjectId])
  @@map("billing_milestones")
}

