// Prisma schema — Hindustan Projects
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────
// Service — IT services offered by the company
// ─────────────────────────────────────────────────────────────────
model Service {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  shortDescription String
  fullDescription  String
  icon             String
  order            Int      @default(0)
  isActive         Boolean  @default(true)
  // Rich detail fields for ServiceDetailPage
  tag              String?              // e.g. "Most Popular"
  deliveryTime     String?              // e.g. "2–4 Weeks"
  techStack        String[]             // e.g. ["React", "Node.js"]
  keyFeatures      String[]             // bullet points
  process          Json?                // [{step, title, desc}]
  colorFrom        String?              // Tailwind gradient from color
  colorTo          String?              // Tailwind gradient to color
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
  @@index([isActive, order])
  @@map("services")
}

// ─────────────────────────────────────────────────────────────────
// Project — Portfolio items
// ─────────────────────────────────────────────────────────────────
model Project {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  clientName   String
  description  String
  thumbnailUrl String?
  images       String[] // Array of image URLs (Cloudinary)
  technologies String[] // e.g. ["React", "Node.js", "PostgreSQL"]
  category     String   // e.g. "Web", "Marketing", "Branding"
  isFeatured   Boolean  @default(false)
  liveUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([isFeatured])
  @@index([category])
  @@map("projects")
}

// ─────────────────────────────────────────────────────────────────
// TeamMember — About page team section
// ─────────────────────────────────────────────────────────────────
model TeamMember {
  id          String   @id @default(cuid())
  name        String
  role        String
  photoUrl    String?
  bio         String?
  linkedinUrl String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([order])
  @@map("team_members")
}

// ─────────────────────────────────────────────────────────────────
// Testimonial — Client reviews
// ─────────────────────────────────────────────────────────────────
model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  text      String
  rating    Int      @default(5)
  avatarUrl String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("testimonials")
}

// ─────────────────────────────────────────────────────────────────
// FAQ — Frequently asked questions
// ─────────────────────────────────────────────────────────────────
model Faq {
  id       String  @id @default(cuid())
  question String
  answer   String
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("faqs")
}

// ─────────────────────────────────────────────────────────────────
// SiteSetting — Key-value store for contact info, social links etc
// ─────────────────────────────────────────────────────────────────
model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// ─────────────────────────────────────────────────────────────────
// Milestone — Company timeline on About page
// ─────────────────────────────────────────────────────────────────
model Milestone {
  id        String   @id @default(cuid())
  year      String
  title     String
  desc      String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
  @@map("milestones")
}

// ─────────────────────────────────────────────────────────────────
// Partner — Client logo banner
// ─────────────────────────────────────────────────────────────────
model Partner {
  id       String  @id @default(cuid())
  name     String
  logoUrl  String?
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, order])
  @@map("partners")
}

// ─────────────────────────────────────────────────────────────────
enum LeadStatus {
  NEW
  CONTACTED
  CLOSED
}

model ContactLead {
  id                String     @id @default(cuid())
  name              String
  email             String
  phone             String?
  message           String
  serviceInterested String?
  status            LeadStatus @default(NEW)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("contact_leads")
}

// ─────────────────────────────────────────────────────────────────
// Admin — CMS dashboard users
// ─────────────────────────────────────────────────────────────────
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@map("admins")
}

// ─────────────────────────────────────────────────────────────────
// Careers — Job Postings & Applications
// ─────────────────────────────────────────────────────────────────
enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
}

enum ApplicationStatus {
  NEW
  SHORTLISTED
  REJECTED
  HIRED
}

model JobPosting {
  id                 String           @id @default(cuid())
  title              String
  slug               String           @unique
  department         String
  location           String
  jobType            JobType          @default(FULL_TIME)
  experienceRequired String
  description        String
  responsibilities   String[]
  requirements       String[]
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  applications       JobApplication[]

  @@index([slug])
  @@index([isActive])
  @@map("job_postings")
}

model JobApplication {
  id           String            @id @default(cuid())
  jobPostingId String
  jobPosting   JobPosting        @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String
  resumeUrl    String
  coverLetter  String?
  status       ApplicationStatus @default(NEW)
  createdAt    DateTime          @default(now())

  @@index([jobPostingId])
  @@map("job_applications")
}

// ─────────────────────────────────────────────────────────────────
// LegalPage — Dynamic terms and policy pages
// ─────────────────────────────────────────────────────────────────
enum LegalPageType {
  PRIVACY_POLICY
  TERMS_OF_SERVICE
  REFUND_POLICY
}

model LegalPage {
  id          String        @id @default(cuid())
  pageType    LegalPageType @unique
  title       String
  content     String        // Stored as long HTML/Markdown text
  lastUpdated DateTime      @default(now()) @updatedAt
  updatedBy   String?       // admin id reference

  @@index([pageType])
  @@map("legal_pages")
}
